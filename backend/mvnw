#!/bin/sh
# Maven wrapper - runs Maven using the wrapper jar
set -e
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

if [ -r "$WRAPPER_JAR" ]; then
  exec java -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" -cp "$WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
fi

# Fallback: try system mvn
if command -v mvn >/dev/null 2>&1; then
  exec mvn "$@"
fi

echo "Maven wrapper jar not found at $WRAPPER_JAR. Run: mvn wrapper:wrapper" 1>&2
echo "Or install Maven and run: mvn compile" 1>&2
exit 1
